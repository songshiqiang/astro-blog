{
	"name": "astroplate",
	"version": "5.12.0",
	"description": "Astro and Tailwindcss boilerplate",
	"author": "zeon.studio",
	"license": "MIT",
	"packageManager": "pnpm@9.15.4",
	"type": "module",
	"scripts": {
		"dev": "concurrently \"node scripts/themeGenerator.js --watch\" \"pnpm generate-json && astro dev\"",
		"build": "node scripts/build-prod.js",
		"preview": "astro preview",
		"check": "astro check",
		"format": "prettier -w ./src",
		"generate-json": "node scripts/jsonGenerator.js"
	},
	"dependencies": {
		"@astrojs/check": "0.9.6",
		"@astrojs/mdx": "4.3.13",
		"@astrojs/react": "4.4.2",
		"@astrojs/sitemap": "3.7.0",
		"@aws-sdk/client-s3": "^3.975.0",
		"@digi4care/astro-google-tagmanager": "^1.6.0",
		"@justinribeiro/lite-youtube": "^1.9.0",
		"@uiw/react-markdown-preview": "^5.1.5",
		"@uiw/react-md-editor": "^4.0.11",
		"astro": "5.16.11",
		"astro-auto-import": "^0.5.1",
		"astro-font": "^1.1.0",
		"astro-swiper": "^1.4.0",
		"date-fns": "^4.1.0",
		"disqus-react": "^1.1.7",
		"dotenv": "^17.2.3",
		"github-slugger": "^2.0.0",
		"gray-matter": "^4.0.3",
		"js-yaml": "^4.1.1",
		"marked": "^17.0.1",
		"mime-types": "^3.0.2",
		"nanoid": "^5.1.6",
		"prop-types": "^15.8.1",
		"react": "^19.2.3",
		"react-dom": "^19.2.3",
		"react-hot-toast": "^2.6.0",
		"react-icons": "^5.5.0",
		"remark-collapse": "^0.1.2",
		"remark-toc": "^9.0.0",
		"sharp": "^0.34.5",
		"swiper": "^12.0.3",
		"vite": "^7.3.1"
	},
	"devDependencies": {
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.1.18",
		"@types/js-yaml": "^4.0.9",
		"@types/node": "25.0.9",
		"@types/react": "19.2.8",
		"@types/react-dom": "19.2.3",
		"concurrently": "^9.2.1",
		"eslint": "^9.39.2",
		"prettier": "^3.8.0",
		"prettier-plugin-astro": "^0.14.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"tailwind-bootstrap-grid": "^6.0.0",
		"tailwindcss": "^4.1.18",
		"typescript": "^5.9.3"
